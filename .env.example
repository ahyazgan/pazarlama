# --- AI uretim (zorunlu, icerik uretimi icin) ---
# ONEMLI: Gercek anahtari ASLA bu dosyaya veya koda yazma; .env.local (git-ignore'li)
# ya da ortam/secret ayarlarina koy. Anahtari paylasinca/sizinca mutlaka revoke et.
ANTHROPIC_API_KEY=sk-ant-...
# Uretim modeli (tum /api route'lari bunu okur).
# Kalite-oncelikli (Constitution varsayilani): claude-sonnet-4-6
# UCUZ DENEME modu (dusuk maliyet, "Opus tarzi" agir kullanimdan kacin): claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Supabase (opsiyonel) ---
# Bos birakilirsa uygulama yine calisir; Marka Beyni tarayicida (localStorage) saklanir.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
